   "source": [
    "def factorial(n):\n",
    "    if n <= 1:\n",
    "        return 1\n",
    "    else:\n",
    "        # calculate n multiplied by the factorial of n - 1\n",
    "        return n * factorial(n - 1)\n",
    "\n",
    "\n",
    "print(factorial(12))"
   ]
  }
 ],
