   "source": [
    "def increment_list(mylist):\n",
    "    \"\"\"This function adds 1 to each element of the list.\"\"\"\n",
    "\n",
    "    for i in range(len(mylist)):\n",
    "        mylist[i] += 1\n",
    "\n",
    "    return mylist\n",
    "\n",
    "\n",
    "print(increment_list.__doc__)\n",
    "print(increment_list([1, 2, 3]))"
   ]
  }
