    "def print_table(height, length=3, symbol='++++'):\n",
    "    for y in range(height):\n",
    "        for x in range(length):\n",
    "            print(f'|{symbol}', end='')\n",
    "        print('|\\n')\n",
    "\n",
    "\n",
    "print_table(5, length=5, symbol='____')"
