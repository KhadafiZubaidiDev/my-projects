   ],
   "source": [
    "def contains_even_number(lst):\n",
    "    for i in lst:\n",
    "        if i % 2 == 0:\n",
    "            print(f\"List {lst} contains an even number.\")\n",
    "            break\n",
    "    else:\n",
    "        print(f\"List {lst} does not contain an even number.\")\n",
    "\n",
    "\n",
    "contains_even_number([1, 9, 8])\n",
    "contains_even_number([1, 3, 5])"
   ]
  }
 ],
